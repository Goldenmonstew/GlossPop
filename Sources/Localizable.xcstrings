    "Skip the system dictionary — words/phrases go straight to the AI dictionary: definition in your second language, meaning in your first.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Systemlexikon überspringen – Wörter/Phrasen gehen direkt ans KI-Lexikon: Definition in deiner Zweitsprache, Bedeutung in deiner Erstsprache."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Omite el diccionario del sistema: las palabras y frases van directas al diccionario de IA, con definición en tu segundo idioma y significado en el primero."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ignore le dictionnaire système — les mots et expressions vont directement au dictionnaire IA : définition dans votre deuxième langue, sens dans votre première."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "システム辞書をスキップ — 単語/フレーズを直接AI辞書で調べます。第二言語での定義と第一言語での意味を表示します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "시스템 사전을 건너뛰고 단어/구를 바로 AI 사전으로 보냅니다. 정의는 제2언어로, 뜻은 제1언어로 제공됩니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
