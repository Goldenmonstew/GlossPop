    "Variables: $text (the selection), $target (target language). Plain translation only — dictionary/syntax keep the built-in prompts.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Variablen: $text (die Auswahl), $target (Zielsprache). Nur einfache Übersetzung – Lexikon/Syntax behalten die integrierten Prompts."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Variables: $text (la selección), $target (idioma de destino). Solo traducción simple: el diccionario y la sintaxis mantienen los prompts integrados."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Variables : $text (la sélection), $target (langue cible). Traduction simple uniquement — le dictionnaire et la syntaxe conservent les prompts intégrés."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "変数: $text（選択テキスト）、$target（翻訳先言語）。プレーン翻訳のみに適用 — 辞書/構文解析は内蔵プロンプトを使用します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "변수: $text(선택한 텍스트), $target(대상 언어). 일반 번역에만 적용되며, 사전/구문 분석은 내장 프롬프트를 사용합니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Переменные: $text (выделенный текст), $target (язык перевода). Только обычный перевод — словарь и синтаксис используют встроенные промпты."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "变量：$text（选中文本）、$target（目标语言）。仅用于普通翻译——词典/句法仍使用内置提示词。"
          }
        },
        "zh-Hant": {
